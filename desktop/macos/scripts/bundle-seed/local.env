# VoiceBridgeAI 本地版 — 首次启动写入 Application Support
# Whisper tiny.en + Argos en→zh 已打入 App；云端密钥来自仓库根目录 .env（打包时合并）
VOICEBRIDGE_BUNDLE_VARIANT=local
VOICEBRIDGE_OPTIONAL_LOCAL_MODELS=0
LOCAL_WHISPER_ENABLED=1
LOCAL_ARGOS_ENABLED=1
AUTO_TEST_ON_START=0
REVISE_MODE=speech
ASR_PROVIDER=local
PARTIAL_PROVIDER=argos
FINAL_PROVIDER=argos
WHISPER_MODEL=tiny.en
