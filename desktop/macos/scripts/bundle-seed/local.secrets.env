# 比赛演示用 — 复制为 local.secrets.env 并填入真实密钥（该文件已被 .gitignore 忽略）
# cp local.secrets.env.example local.secrets.env
#
# 打包时自动合并进 VoiceBridgeAI-Local.app，评审老师首次打开即可用。
# 默认仍走本地 Whisper + Argos；下方密钥供设置页切换云端引擎时使用。
#
# 注意：不要把填好密钥的 .app / local.secrets.env 提交到 Git 或公开网盘。

# --- 腾讯云 ASR（可选，切换云端识别）---
# TENCENT_ASR_APP_ID=
# TENCENT_ASR_SECRET_ID=
# TENCENT_ASR_SECRET_KEY=

# --- 腾讯 TMT 句中翻译（可选）---
# TMT 与 ASR 共用腾讯云密钥

# --- 七牛 / 阿里 / DeepSeek / OpenAI（可选，句末润色）---
# QINIU_AI_API_KEY=
# ALIYUN_AI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=
