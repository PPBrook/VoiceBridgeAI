<Window
    x:Class="VoiceBridgeAI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VoiceBridgeAI"
    Width="460"
    Height="400"
    MinWidth="420"
    MinHeight="360">

    <Grid Padding="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="4">
            <TextBlock
                FontSize="26"
                FontWeight="SemiBold"
                Text="VoiceBridgeAI" />
            <TextBlock
                Style="{StaticResource VbaCaptionStyle}"
                Text="系统音频实时翻译 · 悬浮字幕" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,0,0,20" Style="{StaticResource VbaCardStyle}">
            <StackPanel Spacing="14">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse
                        x:Name="EngineStatusDot"
                        Width="10"
                        Height="10"
                        Fill="{StaticResource VbaStatusIdleBrush}"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock
                            x:Name="StatusText"
                            Style="{StaticResource VbaSectionTitleStyle}"
                            Text="检测引擎…" />
                        <TextBlock
                            x:Name="EngineText"
                            Style="{StaticResource VbaCaptionStyle}"
                            Text="引擎：—" />
                    </StackPanel>
                </Grid>

                <Rectangle
                    Fill="{StaticResource VbaCardBorderBrush}"
                    Height="1" />

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse
                        x:Name="SessionStatusDot"
                        Width="10"
                        Height="10"
                        Fill="{StaticResource VbaStatusIdleBrush}"
                        VerticalAlignment="Top"
                        Margin="0,5,0,0" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock
                            Style="{StaticResource VbaSectionTitleStyle}"
                            Text="悬浮字幕" />
                        <TextBlock
                            x:Name="SessionText"
                            Style="{StaticResource VbaCaptionStyle}"
                            Text="未运行" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Spacing="10">
            <Button
                x:Name="StartSubtitleButton"
                Click="StartSubtitleClicked"
                Content="开始悬浮字幕"
                HorizontalAlignment="Stretch"
                Style="{StaticResource AccentButtonStyle}" />

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="StartEngineButton"
                    Grid.Column="0"
                    Click="StartEngineClicked"
                    Content="启动引擎"
                    HorizontalAlignment="Stretch" />
                <Button
                    x:Name="StopSubtitleButton"
                    Grid.Column="1"
                    Click="StopSubtitleClicked"
                    Content="停止字幕"
                    HorizontalAlignment="Stretch"
                    IsEnabled="False" />
            </Grid>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="RefreshButton" Click="RefreshClicked" Content="刷新状态" />
                <Button x:Name="SettingsButton" Click="SettingsClicked" Content="设置…" />
            </StackPanel>
        </StackPanel>

        <Border
            Grid.Row="3"
            Margin="0,16,0,0"
            Padding="12"
            Background="#12DC2626"
            BorderBrush="#40DC2626"
            BorderThickness="1"
            CornerRadius="8"
            Visibility="Collapsed"
            x:Name="ErrorPanel">
            <TextBlock
                x:Name="ErrorText"
                Foreground="#FFB91C1C"
                Text=""
                TextWrapping="WrapWholeWords" />
        </Border>
    </Grid>
</Window>
