<Window
    x:Class="VoiceBridgeAI.Settings.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="VoiceBridgeAI 设置"
    Width="540"
    Height="520"
    MinWidth="480"
    MinHeight="420">

    <Grid Padding="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20" Spacing="4">
            <TextBlock
                FontSize="22"
                FontWeight="SemiBold"
                Text="引擎设置" />
            <TextBlock
                Style="{StaticResource VbaCaptionStyle}"
                Text="默认可直接用本地 Whisper + Argos。云端推荐句中 MT + 句末 LLM。" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Border Style="{StaticResource VbaCardStyle}">
                <StackPanel Spacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource VbaSectionTitleStyle}" Text="语音识别" />
                        <ComboBox x:Name="AsrCombo" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource VbaSectionTitleStyle}" Text="句中翻译" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="推荐 MT · 实时句中翻译" />
                        <ComboBox x:Name="PartialCombo" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource VbaSectionTitleStyle}" Text="句末润色" />
                        <TextBlock
                            FontSize="11"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="推荐 LLM · 句末润色与断句" />
                        <ComboBox x:Name="FinalCombo" HorizontalAlignment="Stretch" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource VbaSectionTitleStyle}" Text="观看场景" />
                        <ComboBox x:Name="ReviseCombo" HorizontalAlignment="Stretch" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,20,0,0" Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button
                    x:Name="SaveButton"
                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                    Click="SaveClicked"
                    Content="保存引擎"
                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                    MinWidth="120" />
                <Button Click="ReloadClicked" Content="重新加载" />
            </StackPanel>

            <Border
                x:Name="StatusPanel"
                Padding="12,8"
                Background="#0F000000"
                BorderBrush="{StaticResource VbaCardBorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="Collapsed">
                <TextBlock
                    x:Name="StatusText"
                    Style="{StaticResource VbaCaptionStyle}"
                    Text="" />
            </Border>
        </StackPanel>
    </Grid>
</Window>
