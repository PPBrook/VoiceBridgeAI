<Window
    x:Class="VoiceBridgeAI.Overlay.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Grid Background="Transparent" Padding="14,10">
        <Border
            BorderBrush="#24FFFFFF"
            BorderThickness="1"
            CornerRadius="16">
            <Grid>
                <Border
                    x:Name="TintLayer"
                    Background="Black"
                    CornerRadius="16" />
                <Grid x:Name="ContentGrid" Padding="14,10,14,16" RowSpacing="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid x:Name="HeaderHost" Grid.Row="0" />

                    <TextBlock
                        x:Name="HistoryZhLabel"
                        Grid.Row="1"
                        FontSize="14"
                        Foreground="#8FC7C7C7"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />

                    <TextBlock
                        x:Name="ZhLabel"
                        Grid.Row="2"
                        FontSize="24"
                        FontWeight="SemiBold"
                        Foreground="#FAFAFA"
                        Text="等待字幕…"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords" />

                    <TextBlock
                        x:Name="EnLabel"
                        Grid.Row="3"
                        FontSize="13"
                        Foreground="#D0D0D0"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />

                    <TextBlock
                        x:Name="ErrorLabel"
                        Grid.Row="4"
                        Foreground="#FF6B6B"
                        TextAlignment="Center"
                        TextWrapping="WrapWholeWords"
                        Visibility="Collapsed" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
