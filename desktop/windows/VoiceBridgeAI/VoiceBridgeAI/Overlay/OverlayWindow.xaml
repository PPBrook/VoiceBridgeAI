<Window
    x:Class="VoiceBridgeAI.Overlay.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Window.Resources>
        <SolidColorBrush x:Key="ChromeBrush" Color="#B8B8B8" />
        <SolidColorBrush x:Key="ChromeMutedBrush" Color="#8A8A8A" />
        <SolidColorBrush x:Key="DividerBrush" Color="#24FFFFFF" />
        <SolidColorBrush x:Key="CardBorderBrush" Color="#24FFFFFF" />

        <Style x:Key="ChromeCaption" TargetType="TextBlock">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="Foreground" Value="{StaticResource ChromeMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="OverlaySlider" TargetType="Slider">
            <Setter Property="Width" Value="72" />
            <Setter Property="Minimum" Value="0.15" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="StepFrequency" Value="0.01" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="OverlayPillToggle" TargetType="ToggleButton">
            <Setter Property="MinWidth" Value="36" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ChromeBrush}" />
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="BorderBrush" Value="#28FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="OverlayIconButton" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#18FFFFFF" />
            <Setter Property="BorderBrush" Value="#28FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Foreground" Value="{StaticResource ChromeBrush}" />
        </Style>
    </Window.Resources>

    <Grid x:Name="RootGrid" Background="Transparent" Margin="10,8">
        <Border
            x:Name="CardShell"
            Background="Transparent"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="16">

            <Grid>
                <Rectangle
                    x:Name="BackdropFill"
                    Fill="#D21A1A22"
                    RadiusX="16"
                    RadiusY="16" />
                <Rectangle
                    x:Name="TintOverlay"
                    Fill="#85000000"
                    RadiusX="16"
                    RadiusY="16" />

                <Grid Padding="16,12,16,14" RowSpacing="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        x:Name="HeaderRow"
                        Grid.Row="0"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                            <TextBlock
                                x:Name="TitleLabel"
                                FontSize="10"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource ChromeMutedBrush}"
                                Text="VoiceBridgeAI"
                                VerticalAlignment="Center" />
                            <TextBlock
                                x:Name="ModeBadge"
                                FontSize="9"
                                Foreground="{StaticResource ChromeBrush}"
                                TextTrimming="CharacterEllipsis"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Background="Transparent"
                            PointerPressed="DragArea_PointerPressed" />

                        <StackPanel
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Style="{StaticResource ChromeCaption}" Text="背景" />
                                <Slider
                                    x:Name="BgOpacitySlider"
                                    Style="{StaticResource OverlaySlider}"
                                    ToolTipService.ToolTip="背景不透明度"
                                    ValueChanged="BgOpacitySlider_ValueChanged" />
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Style="{StaticResource ChromeCaption}" Text="文字" />
                                <Slider
                                    x:Name="TextOpacitySlider"
                                    Minimum="0.25"
                                    Style="{StaticResource OverlaySlider}"
                                    ToolTipService.ToolTip="字幕文字不透明度"
                                    Width="60"
                                    ValueChanged="TextOpacitySlider_ValueChanged" />
                            </StackPanel>

                            <ToggleButton
                                x:Name="RecordToggle"
                                Checked="RecordToggle_Changed"
                                Content="记"
                                Style="{StaticResource OverlayPillToggle}"
                                ToolTipService.ToolTip="记录中英文字幕（设置 → 字幕记录 可改目录与文件名）"
                                Unchecked="RecordToggle_Changed" />

                            <ToggleButton
                                x:Name="EnToggle"
                                Checked="EnToggle_Changed"
                                Content="EN"
                                Style="{StaticResource OverlayPillToggle}"
                                ToolTipService.ToolTip="切换英文显示"
                                Unchecked="EnToggle_Changed" />

                            <Button
                                x:Name="StopButton"
                                Click="StopClicked"
                                Style="{StaticResource OverlayIconButton}"
                                ToolTipService.ToolTip="停止字幕">
                                <FontIcon
                                    FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                    FontSize="11"
                                    Glyph="&#xE711;" />
                            </Button>
                        </StackPanel>
                    </Grid>

                    <Rectangle
                        Grid.Row="1"
                        Height="1"
                        Margin="0,10,0,10"
                        Fill="{StaticResource DividerBrush}" />

                    <StackPanel Grid.Row="2" Spacing="4">
                        <TextBlock
                            x:Name="HistoryZhLabel"
                            FontSize="14"
                            FontWeight="Medium"
                            Foreground="#C7C7C7"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />

                        <TextBlock
                            x:Name="HistoryEnLabel"
                            FontSize="11"
                            Foreground="#A8A8A8"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />

                        <TextBlock
                            x:Name="ZhLabel"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Foreground="#FAFAFA"
                            Text="等待字幕…"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords" />

                        <TextBlock
                            x:Name="EnLabel"
                            FontSize="13"
                            Foreground="#D0D0D0"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />

                        <TextBlock
                            x:Name="ErrorLabel"
                            FontSize="12"
                            FontWeight="Medium"
                            Foreground="#FF6B6B"
                            TextAlignment="Center"
                            TextWrapping="WrapWholeWords"
                            Visibility="Collapsed" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
