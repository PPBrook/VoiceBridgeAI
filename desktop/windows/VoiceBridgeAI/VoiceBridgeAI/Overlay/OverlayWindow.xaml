<Window
    x:Class="VoiceBridgeAI.Overlay.OverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="12,8">
        <Border
            x:Name="OverlayBorder"
            Background="#C7000000"
            BorderBrush="#24FFFFFF"
            BorderThickness="1"
            CornerRadius="16">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>

            <Grid Padding="16,12,16,18" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 顶栏：标题区可拖拽，控件集中在右侧 pill -->
                <Grid Grid.Row="0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        PointerEntered="DragHandle_PointerEntered"
                        PointerExited="DragHandle_PointerExited"
                        PointerPressed="DragHandle_PointerPressed"
                        Style="{StaticResource OverlayTitleStyle}"
                        Text="VoiceBridgeAI" />

                    <Border
                        Grid.Column="1"
                        Background="Transparent"
                        PointerEntered="DragHandle_PointerEntered"
                        PointerExited="DragHandle_PointerExited"
                        PointerPressed="DragHandle_PointerPressed" />

                    <Border
                        Grid.Column="2"
                        Background="#14FFFFFF"
                        BorderBrush="#18FFFFFF"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8,4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Style="{StaticResource OverlayChromeLabelStyle}" Text="背景" />
                                <Slider
                                    x:Name="BgOpacitySlider"
                                    Width="64"
                                    Maximum="1"
                                    Minimum="0.15"
                                    StepFrequency="0.01"
                                    Style="{StaticResource OverlayMiniSliderStyle}"
                                    ToolTipService.ToolTip="背景不透明度"
                                    ValueChanged="BgOpacitySlider_ValueChanged" />
                            </StackPanel>

                            <Rectangle
                                Width="1"
                                Height="16"
                                Fill="#20FFFFFF"
                                VerticalAlignment="Center" />

                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Style="{StaticResource OverlayChromeLabelStyle}" Text="文字" />
                                <Slider
                                    x:Name="TextOpacitySlider"
                                    Width="52"
                                    Maximum="1"
                                    Minimum="0.25"
                                    StepFrequency="0.01"
                                    Style="{StaticResource OverlayMiniSliderStyle}"
                                    ToolTipService.ToolTip="字幕文字不透明度"
                                    ValueChanged="TextOpacitySlider_ValueChanged" />
                            </StackPanel>

                            <Rectangle
                                Width="1"
                                Height="16"
                                Fill="#20FFFFFF"
                                VerticalAlignment="Center" />

                            <ToggleButton
                                x:Name="EnToggle"
                                Checked="EnToggle_Changed"
                                Content="EN"
                                Style="{StaticResource OverlayToggleStyle}"
                                ToolTipService.ToolTip="切换英文显示"
                                Unchecked="EnToggle_Changed" />

                            <Button
                                Click="StopClicked"
                                Content="×"
                                Style="{StaticResource OverlayStopButtonStyle}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <TextBlock
                    x:Name="HistoryZhLabel"
                    Grid.Row="1"
                    FontSize="14"
                    Foreground="#8FC7C7C7"
                    LineHeight="20"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords"
                    Visibility="Collapsed" />

                <TextBlock
                    x:Name="ZhLabel"
                    Grid.Row="2"
                    FontSize="26"
                    FontWeight="SemiBold"
                    Foreground="#FAFAFA"
                    LineHeight="34"
                    Text="等待字幕…"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords" />

                <TextBlock
                    x:Name="EnLabel"
                    Grid.Row="3"
                    FontSize="13"
                    Foreground="#D0D0D0"
                    LineHeight="18"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords"
                    Visibility="Collapsed" />

                <TextBlock
                    x:Name="ErrorLabel"
                    Grid.Row="4"
                    FontSize="13"
                    Foreground="#FF6B6B"
                    TextAlignment="Center"
                    TextWrapping="WrapWholeWords"
                    Visibility="Collapsed" />
            </Grid>
        </Border>
    </Grid>
</Window>
