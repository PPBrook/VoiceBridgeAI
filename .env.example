# cp .env.example .env
# cp cloud-ui.json.example cloud-ui.json   # 可选：云端卡片隐藏偏好
# App 独立安装时写入 ~/Library/Application Support/VoiceBridgeAI/

VOICEBRIDGE_PORT=8765
VOICEBRIDGE_OPTIONAL_LOCAL_MODELS=1
AUTO_TEST_ON_START=1

ASR_PROVIDER=local
PARTIAL_PROVIDER=argos
FINAL_PROVIDER=argos
REVISE_MODE=speech

# WHISPER_MODEL=tiny.en
# LOCAL_WHISPER_ENABLED=1
# LOCAL_ARGOS_ENABLED=1

# --- 观看场景 REVISE_MODE ---
# speech      演讲 · 跟节奏（默认）
# tech        技术分享 · 术语稳定
# conference  会议 · 低延迟
# course      网课 · 知识点整段

# --- 云端（App 设置页保存，或在此预设）---
