# cp .env.example .env
# App 独立安装时写入 ~/Library/Application Support/VoiceBridgeAI/.env

VOICEBRIDGE_PORT=8765
VOICEBRIDGE_OPTIONAL_LOCAL_MODELS=1
AUTO_TEST_ON_START=1

ASR_PROVIDER=local
PARTIAL_PROVIDER=argos
FINAL_PROVIDER=argos
REVISE_MODE=balanced

# WHISPER_MODEL=tiny.en
# LOCAL_WHISPER_ENABLED=1
# LOCAL_ARGOS_ENABLED=1

