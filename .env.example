# 腾讯云实时语音识别 — https://cloud.tencent.com/document/api/1093/48982
TENCENT_ASR_APP_ID=1250000000
TENCENT_ASR_SECRET_ID=AKIDxxxxxxxx
TENCENT_ASR_SECRET_KEY=xxxxxxxx
TENCENT_ASR_ENGINE=16k_en
# 机器翻译 TMT（双引擎 partial，与 ASR 共用 SecretId/SecretKey）
TMT_REGION=ap-guangzhou
TMT_PROJECT_ID=0
# 七牛 LLM（双引擎 final 润色）— https://developer.qiniu.com/aitokenapi
QINIU_AI_API_KEY=
QINIU_AI_BASE_URL=https://api.qnaigc.com/v1
QINIU_AI_MODEL=qwen-turbo
# 阿里云 DashScope（OpenAI 兼容，可选）
ALIYUN_AI_API_KEY=
ALIYUN_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_AI_MODEL=qwen-turbo
# 识别：tencent（演示推荐）| local（全本地）
ASR_MODE=tencent
# 翻译：dual（演示推荐）| argos（全本地）| local（Google 兜底）
TRANSLATE_MODE=dual
# 纠正模式：speed=实时优先 | balanced=标准纠正（默认）| accuracy=精准纠正
REVISE_MODE=balanced
# 句中修正间隔（秒；精准模式约 0.55，实时优先约 1.2）
REFINE_INTERVAL=0.8
# 草稿翻译 debounce（秒；实时优先约 0.35）
TRANSLATE_DEBOUNCE=0.25
