# 复制为 .env 后生效：cp .env.example .env
# 也可在 http://127.0.0.1:8765 页面「API 配置」填写（当前进程有效）

# ── 默认引擎（三层可独立配置）──────────────────────────────
# ASR_PROVIDER / ASR_MODE: tencent | local
# PARTIAL_PROVIDER: tmt | google | argos | aliyun
# FINAL_PROVIDER: qiniu | aliyun | tmt | google | argos | none
ASR_PROVIDER=tencent
PARTIAL_PROVIDER=tmt
FINAL_PROVIDER=qiniu
REVISE_MODE=balanced

# ── 腾讯云（ASR + TMT）────────────────────────────────────
TENCENT_ASR_APP_ID=1250000000
TENCENT_ASR_SECRET_ID=AKIDxxxxxxxx
TENCENT_ASR_SECRET_KEY=xxxxxxxx
TENCENT_ASR_ENGINE=16k_en
TMT_REGION=ap-guangzhou
TMT_PROJECT_ID=0

# ── 七牛 AI（句末 LLM 可选）────────────────────────────────
QINIU_AI_API_KEY=
QINIU_AI_BASE_URL=https://api.qnaigc.com/v1
QINIU_AI_MODEL=qwen-turbo

# ── 阿里云 DashScope（句中/句末 LLM 可选）──────────────────
ALIYUN_AI_API_KEY=
ALIYUN_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
ALIYUN_AI_MODEL=qwen-turbo

# ── 本地识别（可选微调）──────────────────────────────────
REFINE_INTERVAL=0.8
