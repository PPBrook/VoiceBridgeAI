# cp .env.example .env
# 密钥可在此预设；阅读版见 http://127.0.0.1:8765/guide/provider-keys
# 组合教程见 docs/ENGINE_PAIRING.md

# --- 引擎默认（方案 C 全本地，开箱即用）---
ASR_PROVIDER=local
PARTIAL_PROVIDER=argos
FINAL_PROVIDER=argos
REVISE_MODE=balanced
VOICEBRIDGE_PORT=8765
AUTO_TEST_ON_START=1

# --- 方案 A 国内低延迟示例（取消注释并填 Key）---
# ASR_PROVIDER=tencent
# PARTIAL_PROVIDER=tmt
# FINAL_PROVIDER=qiniu

# --- 腾讯云 ---
# TENCENT_ASR_APP_ID=
# TENCENT_ASR_SECRET_ID=
# TENCENT_ASR_SECRET_KEY=
# TENCENT_ASR_ENGINE=16k_en
# TMT_REGION=ap-shanghai
# TMT_PROJECT_ID=0

# --- 七牛 AI ---
# QINIU_AI_API_KEY=
# QINIU_AI_BASE_URL=https://api.qnaigc.com/v1
# QINIU_AI_MODEL=qwen-turbo

# --- 阿里云 DashScope ---
# ALIYUN_AI_API_KEY=
# ALIYUN_AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# ALIYUN_AI_MODEL=qwen-turbo

# --- DeepSeek / OpenAI ---
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_ASR_MODEL=whisper-1

# --- 百度 / DeepL ---
# BAIDU_APP_ID=
# BAIDU_SECRET_KEY=
# DEEPL_API_KEY=
# DEEPL_API_URL=https://api.deepl.com/v2/translate

# --- 本地 Whisper（ASR_PROVIDER=local 时）---
# WHISPER_MODEL=base.en
